# CampusLens API keys — DO NOT COMMIT THIS FILE
# Copy to .env and fill in your keys

# College Scorecard (free: https://api.data.gov/signup/) — optional, DEMO_KEY works
SCORECARD_API_KEY=

# Census API (free: https://api.census.gov/data/key_signup.html) — needed for permits
CENSUS_API_KEY=

# Google Maps Platform — needed for frontend map
GOOGLE_MAPS_API_KEY=

# Google AI / Gemini — needed for Phase 3
GEMINI_API_KEY=
