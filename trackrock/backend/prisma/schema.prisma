generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Properties ────────────────────────────────────────────────────────────────

model Property {
  id               String   @id
  propertyAddress  String
  mailingAddress   String?
  ownerName        String
  matchReason      String
  parentEntity     String   @default("OTHER")
  subsidiaryChain  String[]
  confidenceScore  Float    @default(0)
  confidenceReason String?
  lat              Float?
  lng              Float?
  fipsTract        String?
  zipCode          String?
  acquisitionYear  Int?
  purchasePrice    Float?
  city             String   @default("Austin")
  state            String   @default("TX")
  geocodedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([fipsTract])
  @@index([parentEntity])
  @@index([zipCode])
  @@index([acquisitionYear])
  @@index([city])
  @@index([confidenceScore])
}

// ── Census tract demographics + housing metrics ───────────────────────────────

model TractMetrics {
  id                String  @id @default(cuid())
  fipsTract         String
  year              Int
  medianIncome      Float?
  pctRenter         Float?
  pctWhite          Float?
  pctBlack          Float?
  pctHispanic       Float?
  pctAsian          Float?
  homeownershipRate Float?
  totalHousingUnits Int?
  medianRent        Float?
  city              String?
  county            String?
  state             String?
  createdAt         DateTime @default(now())

  @@unique([fipsTract, year])
  @@index([fipsTract])
  @@index([city])
}

// ── Zillow/HUD/FRED price indices ─────────────────────────────────────────────

model PriceIndex {
  id        String   @id @default(cuid())
  zipCode   String
  year      Int
  month     Int?
  zhvi      Float?
  zori      Float?
  fmr       Float?
  city      String?
  state     String?
  createdAt DateTime @default(now())

  @@unique([zipCode, year, month])
  @@index([zipCode])
  @@index([city])
}

// ── Eviction Lab data ─────────────────────────────────────────────────────────

model EvictionRate {
  id                 String   @id @default(cuid())
  fipsTract          String
  year               Int
  evictionRate       Float?
  evictionFilingRate Float?
  evictions          Int?
  evictionFilings    Int?
  city               String?
  state              String?
  createdAt          DateTime @default(now())

  @@unique([fipsTract, year])
  @@index([fipsTract])
}

// ── Computed concentration scores ─────────────────────────────────────────────

model ConcentrationScore {
  id                  String   @id @default(cuid())
  fipsTract           String   @unique
  city                String?
  state               String?
  totalSfrUnits       Int?
  blackrockOwnedUnits Int      @default(0)
  concentrationPct    Float    @default(0)
  computedAt          DateTime @default(now())

  @@index([city])
  @@index([concentrationPct])
}

// ── Known subsidiary / LLC entity table ───────────────────────────────────────

model SubsidiaryEntity {
  id              String   @id @default(cuid())
  llcName         String   @unique
  parentEntity    String
  confidence      Float
  source          String   // "seed_list" | "gemini"
  registeredState String?
  registeredAgent String?
  createdAt       DateTime @default(now())

  @@index([parentEntity])
}

// ── Pipeline job tracking ─────────────────────────────────────────────────────

model PipelineJob {
  id           String    @id @default(cuid())
  stage        String    // "ingest" | "resolve" | "geocode" | "normalize" | "concentration"
  status       String    @default("pending") // "pending" | "running" | "complete" | "failed"
  city         String?
  startedAt    DateTime?
  completedAt  DateTime?
  errorMsg     String?
  rowsProcessed Int?
  createdAt    DateTime  @default(now())

  @@index([stage])
  @@index([status])
}
